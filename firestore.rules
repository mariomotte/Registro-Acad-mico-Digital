rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a Database-Backed Access Control (DBAC) model for an educational tracking system. 
     * It prioritizes "Authorization Independence" by using dedicated role collections to determine permissions 
     * through document existence checks rather than inspecting fields within a user's profile.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Role Checks (DBAC Pattern: Existence over Content)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isDirector() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_director/$(request.auth.uid));
    }

    function isDocente() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_docente/$(request.auth.uid));
    }

    function isAuxiliar() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_auxiliar/$(request.auth.uid));
    }

    function isPsicologo() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_psicologo/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isDirector() || isDocente() || isAuxiliar() || isPsicologo();
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    // Marker collections for Role-Based Access Control
    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_director/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(uid);
    }
    match /roles_docente/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(uid);
    }
    match /roles_auxiliar/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(uid);
    }
    match /roles_psicologo/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(uid);
    }

    match /students/{studentId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff() && resource != null;
      allow delete: if isAdmin();
    }

    match /incidences/{incidenceId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.registradorUserId == request.auth.uid;
      allow update: if isStaff() && resource != null && request.resource.data.registradorUserId == resource.data.registradorUserId;
      allow delete: if isAdmin() || (resource != null && resource.data.registradorUserId == request.auth.uid);

      match /evidences/{evidenceId} {
        allow get, list: if isStaff();
        allow create: if isStaff() && request.resource.data.registradorUserId == request.auth.uid;
        allow update: if isStaff() && resource != null && request.resource.data.registradorUserId == resource.data.registradorUserId;
        allow delete: if isAdmin() || (resource != null && resource.data.registradorUserId == request.auth.uid);
      }
    }

    match /psychological_sessions/{sessionId} {
      allow get, list: if isPsicologo() || isAdmin() || isDirector();
      allow create: if isPsicologo() && request.resource.data.psicologoId == request.auth.uid;
      allow update: if isPsicologo() && resource != null && resource.data.psicologoId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow get, list: if isStaff();
      allow create, update: if isAdmin() || isDirector();
      allow delete: if isAdmin();
    }
  }
}