rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role Checks (DBAC Pattern: Existence over Content)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isStaff() {
      // For MVP, if they are signed in and have a document in the users collection, they are staff
      // This avoids complex marker checks during the injection/stress test phase
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_director/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_docente/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_auxiliar/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_psicologo/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Marker collections for Role-Based Access Control
    match /roles_admin/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_director/{uid} { allow read: if isSignedIn(); allow write: if isAdmin() || isOwner(uid); }
    match /roles_docente/{uid} { allow read: if isSignedIn(); allow write: if isAdmin() || isOwner(uid); }
    match /roles_auxiliar/{uid} { allow read: if isSignedIn(); allow write: if isAdmin() || isOwner(uid); }
    match /roles_psicologo/{uid} { allow read: if isSignedIn(); allow write: if isAdmin() || isOwner(uid); }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /incidences/{incidenceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}