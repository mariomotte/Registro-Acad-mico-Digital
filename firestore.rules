rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (EduControl.A.G.G)
    // Se permite lectura y escritura a cualquier usuario autenticado en todas las colecciones.
    // Esto asegura que la inyección masiva de 500 alumnos funcione sin errores de permisos.

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    match /incidences/{incidenceId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    match /psychological_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    // Regla comodín para cualquier otra colección o subcolección
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}