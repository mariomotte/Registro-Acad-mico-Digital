rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v11.0)
    // Se permite lectura y escritura a cualquier usuario autenticado en todas las colecciones.
    // Esto es necesario para las operaciones masivas de inyección y limpieza de datos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Reglas explícitas para colecciones principales para evitar errores de propagación
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    match /incidences/{incidenceId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
  }
}