rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrador'
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Marker collections for Role-Based Access Control
    match /roles_admin/{uid} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roles_director/{uid} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /roles_docente/{uid} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /roles_auxiliar/{uid} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /roles_psicologo/{uid} { allow read: if isSignedIn(); allow write: if isSignedIn(); }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /incidences/{incidenceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /psychological_sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}