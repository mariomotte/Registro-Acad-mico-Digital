rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD v15.2 - DESPLIEGUE FORZADO
    // Permisos totales para usuarios autenticados en todas las colecciones.
    // Esta regla global asegura que las consultas de listado (list) y lectura (get) no fallen.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas adicionales para garantizar la propagación en colecciones críticas
    match /incidences/{docId} {
      allow read, write: if request.auth != null;
    }

    match /students/{docId} {
      allow read, write: if request.auth != null;
    }

    match /alerts/{docId} {
      allow read, write: if request.auth != null;
    }

    match /users/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}