rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v15.0)
    // Permitimos lectura y escritura a cualquier usuario autenticado en todas las colecciones.
    // Esto asegura que las consultas complejas y listados no fallen por permisos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regla explícita para la colección de incidencias para asegurar que no haya bloqueos
    match /incidences/{docId} {
      allow read, write: if request.auth != null;
    }

    match /students/{docId} {
      allow read, write: if request.auth != null;
    }

    match /alerts/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}