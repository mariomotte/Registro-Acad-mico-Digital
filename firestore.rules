rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD v17.0 - DESPLIEGUE CRÍTICO
    // Se otorga acceso total de lectura y escritura a cualquier usuario autenticado.
    // Esta regla global resuelve los errores de permisos en las colecciones de incidencias y alumnos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}