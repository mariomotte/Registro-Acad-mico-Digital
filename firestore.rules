rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (EduControl.A.G.G)
    // Se permite lectura y escritura a cualquier usuario autenticado en todas las colecciones.
    // Esto es necesario para la inyección masiva de 500 alumnos y sus reportes.
    // v2.1 - Acceso global para usuarios autenticados

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}