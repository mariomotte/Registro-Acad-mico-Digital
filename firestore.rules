rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---
    // Simplified rules for prototyping to ensure the user can test all features without permission blocks.

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /roles_admin/{uid} { allow read, write: if isSignedIn(); }
    match /roles_director/{uid} { allow read, write: if isSignedIn(); }
    match /roles_docente/{uid} { allow read, write: if isSignedIn(); }
    match /roles_auxiliar/{uid} { allow read, write: if isSignedIn(); }
    match /roles_psicologo/{uid} { allow read, write: if isSignedIn(); }

    match /students/{id} {
      allow read, write: if isSignedIn();
    }

    match /incidences/{id} {
      allow read, write: if isSignedIn();
    }

    match /alerts/{id} {
      allow read, write: if isSignedIn();
    }

    match /psychological_sessions/{id} {
      allow read, write: if isSignedIn();
    }
  }
}