rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v5.0)
    // Se otorga acceso total a cualquier usuario autenticado para facilitar pruebas masivas y stress tests.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Forzado de despliegue crítico: 2024-05-25 22:15 (v5.0)
  }
}