rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a Database-Backed Access Control (DBAC) model for an educational tracking system. 
     * It prioritizes "Authorization Independence" by using dedicated role collections to determine permissions 
     * through document existence checks rather than inspecting fields within a user's profile.
     *
     * DATA STRUCTURE
     * - /users/{userId}: Private user profile data.
     * - /roles_{roleName}/{uid}: Marker documents used for high-performance, atomic role-based authorization.
     * - /students, /incidences, /alerts: Shared educational data accessed by staff based on their assigned roles.
     *
     * KEY SECURITY DECISIONS
     * - Role Validation: Roles are verified via `exists()` calls to specific role collections (/roles_admin, etc.).
     * - Denormalization for Authorization: Critical context (like registradorUserId) is stored directly on documents
     *   to allow rules to make decisions without expensive recursive `get()` calls.
     * - Structural Segregation: System-generated alerts are separated from user-created incidences to allow 
     *   distinct permission sets for Directors and Admins.
     * - Write Protection: All write operations require verified identity and appropriate role or ownership status.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // Role Checks (DBAC Pattern: Existence over Content)
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isDirector() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_director/$(request.auth.uid));
    }

    function isDocente() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_docente/$(request.auth.uid));
    }

    function isAuxiliar() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_auxiliar/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isDirector() || isDocente() || isAuxiliar();
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Users manage their own profile; staff can view profiles.
     * @path /users/{userId}
     * @allow (get) If the user is the owner or a member of the staff.
     * @deny (create) If the authenticated UID does not match the document ID.
     * @principle Enforces path-based ownership and self-creation for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Marker collections for Role-Based Access Control. Only Admins can modify roles.
     * @path /roles_{roleType}/{uid}
     * @allow (get) Any signed-in user (required for exists() checks in rules).
     * @deny (write) Any non-admin user attempting to change roles.
     * @principle Database-Backed Access Control (DBAC) via existence checks.
     */
    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_director/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_docente/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /roles_auxiliar/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Centralized student profile data. Accessible by all educational staff.
     * @path /students/{studentId}
     * @allow (create) If the user has a recognized staff role.
     * @deny (delete) If the user is not an administrator.
     * @principle Shared access for closed collaborators (staff roles).
     */
    match /students/{studentId} {
      allow get, list: if isStaff();
      allow create: if isStaff();
      allow update: if isStaff() && resource != null;
      allow delete: if isAdmin();
    }

    /**
     * @description Incident reports linked to students. Includes denormalized data for audit.
     * @path /incidences/{incidenceId}
     * @allow (create) If staff UID matches the registradorUserId field.
     * @deny (update) If the registradorUserId is being changed (immutability).
     * @principle Relational integrity via denormalized ownership fields.
     */
    match /incidences/{incidenceId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.registradorUserId == request.auth.uid;
      allow update: if isStaff() && resource != null && request.resource.data.registradorUserId == resource.data.registradorUserId;
      allow delete: if isAdmin() || (resource != null && resource.data.registradorUserId == request.auth.uid);

      /**
       * @description Evidence subcollection. Inherits context from parent but uses denormalization.
       * @path /incidences/{incidenceId}/evidences/{evidenceId}
       * @allow (create) If staff UID matches the denormalized registradorUserId.
       * @principle Authorization Independence: Rules avoid parent get() by using internal fields.
       */
      match /evidences/{evidenceId} {
        allow get, list: if isStaff();
        allow create: if isStaff() && request.resource.data.registradorUserId == request.auth.uid;
        allow update: if isStaff() && resource != null && request.resource.data.registradorUserId == resource.data.registradorUserId;
        allow delete: if isAdmin() || (resource != null && resource.data.registradorUserId == request.auth.uid);
      }
    }

    /**
     * @description Automated alerts for high-frequency incidents. Restricted to leadership.
     * @path /alerts/{alertId}
     * @allow (read) Only for Directors and Administrators.
     * @deny (write) All users; these documents are system-generated.
     * @principle Structural Segregation for privileged reporting.
     */
    match /alerts/{alertId} {
      allow get, list: if isAdmin() || isDirector();
      allow create, update, delete: if false; 
    }
  }
}