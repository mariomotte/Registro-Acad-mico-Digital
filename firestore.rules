rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v7.0)
    // Despliegue forzado para resolver error persistente de permisos en 'list incidences'
    // Fecha: 2024-05-26 11:15
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Reglas explícitas para colecciones críticas para asegurar la evaluación del motor
    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    match /incidences/{incidenceId} {
      allow read, write: if request.auth != null;
    }
    
    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}