rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v9.0)
    // Despliegue forzado para resolver error de permisos persistente.
    // Se permite lectura y escritura a CUALQUIER usuario autenticado en todas las colecciones.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}