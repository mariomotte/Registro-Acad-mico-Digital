rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v13.0)
    // Forzando despliegue global para usuarios autenticados.
    // Esto permite que las consultas de listado funcionen sin restricciones de permisos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}