rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLAS DE SEGURIDAD PARA PROTOTIPADO (v8.0)
    // Despliegue forzado: Acceso total para usuarios autenticados
    // Esto garantiza que 'list incidences' y otras consultas funcionen sin errores de permisos.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}